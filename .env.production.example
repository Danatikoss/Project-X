# ─── Скопируйте этот файл в .env.production и заполните значения ───────────
# cp .env.production.example .env.production

# PostgreSQL (должно совпадать с docker-compose.yml)
POSTGRES_DB=slidex
POSTGRES_USER=slidex
POSTGRES_PASSWORD=замените_на_сильный_пароль

DATABASE_URL=postgresql://slidex:замените_на_сильный_пароль@db:5432/slidex

# OpenAI / OpenRouter
OPENAI_API_KEY=ваш_ключ
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Директории внутри контейнера (не менять)
UPLOAD_DIR=/app/data/uploads
THUMBNAIL_DIR=/app/data/thumbnails
EXPORT_DIR=/app/data/exports

# Модели AI
EMBEDDING_MODEL=text-embedding-3-small
ASSEMBLY_MODEL=gpt-4o

# Лимит загрузки
MAX_UPLOAD_SIZE_MB=500

# CORS: только ваш домен
ALLOWED_ORIGINS=https://YOUR_DOMAIN

# JWT: ОБЯЗАТЕЛЬНО сгенерировать случайную строку!
# python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=замените_на_случайную_строку_64_символа
